<section class="viewer-3d" aria-label="3D viewer">
  <header class="viewer-3d-header"><span>3D Viewer</span><strong>Power</strong></header>
  <div class="viewer-3d-export" data-definition="Power" data-symbol-count="13">
    <span data-symbol="Power" data-face="front" data-position="3,1,0">Power</span>
    <span data-symbol="n" data-face="front" data-position="10,1,0">n</span>
    <span data-symbol="e" data-face="front" data-position="17,1,0">e</span>
    <span data-symbol="p" data-face="front" data-position="29,1,0">p</span>
  </div>
  <div class="viewer-3d-assets" data-module="three" data-entry="viewer3d" data-export="window.discoveryOne3dSymbols"></div>
  <output class="viewer-3d-status" aria-label="3D viewer status">Pending: Power symbol export and three.js scene are not implemented yet.</output>
</section>
