*syntax unless _ do _ end expand
  @front
    unless COND do BODY end
    expands to if not COND:
      BODY

  @internal
    template unless _ do _ end
    expansion if not _:
      _

*UnlessCounter
  @front
    i <- 1
    unless i > 3 do
      print i
      i <- i + 1
    end
    i - 1

  @left
    inputs: none

  @right
    output: Int

  @top
    i starts at 1

  @bottom
    prints 1 2 3 and returns 3
