*syntax do _ while _ end expand
  @front
    do BODY while COND end
    expands to while COND:
      BODY

  @internal
    template do _ while _ end
    expansion while _:
      _

*DowhileCounter
  @front
    i <- 1
    do
      print i
      i <- i + 1
    while i <= 3 end
    i - 1

  @left
    inputs: none

  @right
    output: Int

  @top
    i starts at 1

  @bottom
    prints 1 2 3 and returns 3
